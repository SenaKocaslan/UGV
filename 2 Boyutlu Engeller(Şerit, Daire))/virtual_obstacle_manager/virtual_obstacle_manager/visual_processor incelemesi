"""
    # -----------------------------------------------------------------------
    def _detect_trap(self, frame):
        
        Dönüş: (detected: bool, trap_x: int, trap_y: int, contour)
        trap_y eklendi → derinlik haritasında y koordinatı da gerekli
        

        #kontürleri bulma yöntemi, puanlama yöntemi değiştirilebilir

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        cv2.imshow("tuzak içn girye çevrilmiş",gray)
        blur = cv2.GaussianBlur(gray, (9, 9), 0)
        cv2.imshow("tuzak içn blurlanmış",blur)

        thresh_adapt = cv2.adaptiveThreshold(
            blur, 255,
            cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
            cv2.THRESH_BINARY, 25, -8    #25x25 lik komşuluk ayarı
        )
        _, thresh_fixed = cv2.threshold(blur, 160, 255, cv2.THRESH_BINARY)
        mask = cv2.bitwise_and(thresh_fixed, thresh_adapt)    

        k_close = np.ones((11, 11), np.uint8)
        k_open  = np.ones((5,  5),  np.uint8)
        mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, k_close)

        cv2.imshow("tuzak maksesi 1",mask)

        mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN,  k_open)

        cv2.imshow("tuzak maskesi 2",mask)


        contours, _ = cv2.findContours(
            mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        

      

        best_trap  = None
        best_score = 0
        trap_x     = self.img_width  // 2
        trap_y     = self.img_height // 2   # ← YENİ: y merkezi

        for cnt in contours:
            area = cv2.contourArea(cnt)
            if area < self.trap_min_area or area > self.trap_max_area:
                continue

            perimeter = cv2.arcLength(cnt, True)
            if perimeter < 1:  #
                continue

            circularity = (4 * np.pi * area) / (perimeter ** 2)
            if circularity < self.min_circularity:
                continue

            x, y, w, h = cv2.boundingRect(cnt)
            aspect = float(max(w, h)) / max(min(w, h), 1)
            if aspect > self.max_aspect:
                continue

            ellipse_score = 0.0
            if len(cnt) >= 5:
                try:
                    ellipse   = cv2.fitEllipse(cnt)
                    ew, eh    = ellipse[1]
                    ellipse_area = np.pi * (ew / 2) * (eh / 2)
                    if ellipse_area > 0:
                        ellipse_score = min(area, ellipse_area) / max(area, ellipse_area)
                except Exception:
                    pass

            combined_score = circularity * 0.5 + ellipse_score * 0.5
            if combined_score < 0.30:
                continue

            final_score = area * combined_score
            if final_score > best_score:
                best_score = final_score
                best_trap  = cnt
                M = cv2.moments(cnt)
                if M["m00"] != 0:     # resimdeki beyaz piksellerin bu işlemden yalnızca beyaz daire olmasını bekliyoruz ve m00 momenti resimdeki bu beyaz piksellerin toplam sayısını yani tuzağın toplam alanını verir
                    trap_x = int(M["m10"] / M["m00"])   # x eksenindeki ilk momentin toplam beyaz piksel sayısına bölünmesi ile tuzağın x eksenindeki merkezi bulunur
                    trap_y = int(M["m01"] / M["m00"])   # ← YENİ    Y ekseninde ilk momentin toplam beyaz piksel sayısına bölünmesi tuzağın y eksenindeki merkezi bulunur
                                                        # kısacaası toplam ağırlık toplam alana bölünerek ağırlık merkezi bulunuyor

        return (best_trap is not None), trap_x, trap_y, best_trap
