<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rover">

  <!-- Property Definitions -->
  <xacro:property name="body_l" value="0.90"/>
  <xacro:property name="body_w" value="0.55"/>
  <xacro:property name="body_h" value="0.18"/>
  <xacro:property name="wheel_radius" value="0.055"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="side_y" value="0.32"/>
  <xacro:property name="body_z"  value="0.16"/>
  <xacro:property name="wheel_z" value="${wheel_radius}"/> 
  <xacro:property name="plate_z" value="0.12"/>
  
  <!-- PI constant -->
  <xacro:property name="PI" value="3.1415926535897931"/>

  <!-- Base Footprint -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
      <geometry> 
        <box size="${body_l} ${body_w} ${body_h}"/> 
      </geometry>
      <material name="metal"> 
        <color rgba="0.7 0.7 0.75 1"/> 
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
      <geometry> 
        <box size="${body_l} ${body_w} ${body_h}"/> 
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
      <mass value="30"/>
      <inertia ixx="1.5" iyy="2.5" izz="3.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Gazebo specific settings for base_link -->
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <selfCollide>false</selfCollide>
    <gravity>true</gravity>
  </gazebo>

  <!-- Track Body Macro -->
  <xacro:macro name="track_body" params="name y_offset">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
        <geometry> 
          <box size="0.90 0.08 0.25"/> 
        </geometry>
        <material name="dark"> 
          <color rgba="0.2 0.2 0.2 1"/> 
        </material>
      </visual>
      <collision> 
        <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
        <geometry> 
          <box size="0.90 0.08 0.25"/> 
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${body_z}" rpy="0 0 0"/>
        <mass value="2.0"/>
        <inertia ixx="0.05" iyy="0.15" izz="0.15" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 ${y_offset} 0" rpy="0 0 0"/>
    </joint>

    <!-- Gazebo specific settings for track bodies -->
    <gazebo reference="${name}">
      <material>Gazebo/Black</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <selfCollide>false</selfCollide>
    </gazebo>
  </xacro:macro>

  <!-- Create Left and Right Track Bodies -->
  <xacro:track_body name="left_track_body" y_offset="${side_y}"/>
  <xacro:track_body name="right_track_body" y_offset="-${side_y}"/>

  <!-- Road Wheel Macro -->
  <xacro:macro name="road_wheel" params="name x y">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry> 
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/> 
        </geometry>
        <material name="wheel"> 
          <color rgba="0.3 0.3 0.3 1"/> 
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry> 
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/> 
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.8"/>
        <inertia ixx="0.0012" iyy="0.0012" izz="0.0020" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Gazebo specific settings for wheels -->
    <gazebo reference="${name}">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>1.0</maxVel>
      <material>Gazebo/DarkGrey</material>
      <selfCollide>false</selfCollide>
    </gazebo>
  </xacro:macro>

  <!-- Create Left Wheels -->
  <xacro:road_wheel name="lw1" x="0.35"  y="${side_y}"/>
  <xacro:road_wheel name="lw2" x="0.12"  y="${side_y}"/>
  <xacro:road_wheel name="lw3" x="-0.12" y="${side_y}"/>
  <xacro:road_wheel name="lw4" x="-0.35" y="${side_y}"/>

  <!-- Create Right Wheels -->
  <xacro:road_wheel name="rw1" x="0.35"  y="-${side_y}"/>
  <xacro:road_wheel name="rw2" x="0.12"  y="-${side_y}"/>
  <xacro:road_wheel name="rw3" x="-0.12" y="-${side_y}"/>
  <xacro:road_wheel name="rw4" x="-0.35" y="-${side_y}"/>

  <!-- Gazebo Differential Drive Plugin -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      
      <!-- Update rate -->
      <update_rate>50</update_rate>
      
      <!-- Number of wheel pairs -->
      <num_wheel_pairs>4</num_wheel_pairs>

      <!-- Left wheels -->
      <left_joint>lw1_joint</left_joint>
      <left_joint>lw2_joint</left_joint>
      <left_joint>lw3_joint</left_joint>
      <left_joint>lw4_joint</left_joint>

      <!-- Right wheels -->
      <right_joint>rw1_joint</right_joint>
      <right_joint>rw2_joint</right_joint>
      <right_joint>rw3_joint</right_joint>
      <right_joint>rw4_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>${side_y * 2}</wheel_separation>
      <wheel_diameter>${wheel_radius * 2}</wheel_diameter>
      
      <!-- Limits -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- Output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <!-- Frames -->
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>

      <!-- Odometry source -->
      <odometry_source>world</odometry_source>
    </plugin>
  </gazebo>

  <!-- Gazebo Physics Engine Settings -->
  <gazebo>
    <static>false</static>
  </gazebo>

</robot>
